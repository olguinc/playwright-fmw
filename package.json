{
  "name": "playwright-fmw",
  "version": "1.0.0",
  "description": "Playwright framework for testing web applications",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --project=chromium --grep @smoke",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:ci": "npx playwright test --reporter=html,line",
    "test:ci:smoke": "npx playwright test --project=chromium --grep @smoke --reporter=line",
    "test:ci:matrix": "npx playwright test --reporter=html,line",
    "report": "npx playwright show-report",
    "typecheck": "npx tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olguinc/playwright-fmw.git"
  },
  "keywords": [],
  "author": "Carolina Olguin",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/olguinc/playwright-fmw/issues"
  },
  "homepage": "https://github.com/olguinc/playwright-fmw#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2",
    "typescript": "^5.9.3"
  }
}
